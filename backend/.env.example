# Server
HOST=0.0.0.0
PORT=1337

# Frontend URL (для CORS) — вставить после деплоя на Vercel
FRONTEND_URL=https://your-site.vercel.app

# Secrets — сгенерировать новые для продакшена
# node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# Database — PostgreSQL (Railway заполнит автоматически)
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL=true

# Cloudinary — регистрация на cloudinary.com → Dashboard → API Keys
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
